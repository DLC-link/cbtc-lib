# Canton CBTC Library Configuration
#
# Setup:
#   1. Copy environments.example.toml to environments.toml
#   2. Fill in your credentials in environments.toml
#   3. Generate .env:  nu env.nu <environment> <credential>
#
# Examples:
#   nu env.nu                        # list available profiles
#   nu env.nu mainnet attestor       # mainnet with attestor credentials
#   nu env.nu devnet wallet-user     # devnet with wallet-user credentials
#
# The generated .env will contain merged values from:
#   shared settings + environment settings + credential settings
#
# Do not edit .env directly — edit environments.toml instead.

# --- Required variables (set via environments.toml) ---
# LEDGER_HOST=
# ATTESTOR_URL=
# CANTON_NETWORK=
# DECENTRALIZED_PARTY_ID=
# REGISTRY_URL=
# KEYCLOAK_HOST=
# KEYCLOAK_REALM=
# KEYCLOAK_CLIENT_ID=
# PARTY_ID=
#
# Plus one of:
#   Password grant:    KEYCLOAK_USERNAME + KEYCLOAK_PASSWORD
#   Client credentials: KEYCLOAK_CLIENT_SECRET (+ optional KEYCLOAK_TOKEN_ENDPOINT)
