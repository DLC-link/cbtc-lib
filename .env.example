# Canton CBTC Library Configuration
# Copy this file to .env and fill in your values
# Comment/uncomment environment blocks and credential sets to switch

# =============================================================================
# ENVIRONMENT: DEVNET (uncomment this block)
# =============================================================================
# LEDGER_HOST=http://localhost:7575
# ATTESTOR_URL=https://devnet.dlc.link/attestor-2
# CANTON_NETWORK=canton-devnet
# DECENTRALIZED_PARTY_ID=cbtc-network::12202a83c6f4082217c175e29bc53da5f2703ba2675778ab99217a5a881a949203ff
# REGISTRY_URL=https://api.utilities.digitalasset-dev.com
# KEYCLOAK_HOST=https://keycloak.dev.canton.ibtc.network
# KEYCLOAK_REALM=ibtc-catalyst-devnet
# KEYCLOAK_CLIENT_ID=your-client-id
# KEYCLOAK_USERNAME=your-username
# KEYCLOAK_PASSWORD=your-password
# PARTY_ID=your-party::1220...

# =============================================================================
# ENVIRONMENT: TESTNET (uncomment this block)
# =============================================================================
# LEDGER_HOST=https://participant.testnet.example.com
# ATTESTOR_URL=https://testnet.dlc.link/attestor-1
# CANTON_NETWORK=canton-testnet
# DECENTRALIZED_PARTY_ID=cbtc-network::12201b1741b63e2494e4214cf0bedc3d5a224da53b3bf4d76dba468f8e97eb15508f
# REGISTRY_URL=https://api.utilities.digitalasset-staging.com
# KEYCLOAK_HOST=https://keycloak.testnet.example.com
# KEYCLOAK_REALM=your-testnet-realm
# KEYCLOAK_CLIENT_ID=your-client-id
# KEYCLOAK_USERNAME=your-username
# KEYCLOAK_PASSWORD=your-password
# PARTY_ID=your-party::1220...

# =============================================================================
# ENVIRONMENT: MAINNET (uncomment this block)
# =============================================================================
# LEDGER_HOST=https://participant.mainnet.example.com
# ATTESTOR_URL=https://mainnet.dlc.link/attestor-1
# CANTON_NETWORK=canton-mainnet
# DECENTRALIZED_PARTY_ID=cbtc-network::12205af3b949a04776fc48cdcc05a060f6bda2e470632935f375d1049a8546a3b262
# REGISTRY_URL=https://api.utilities.digitalasset.com
# KEYCLOAK_HOST=https://keycloak.mainnet.example.com
# KEYCLOAK_REALM=your-mainnet-realm

# --- Mainnet credentials: uncomment one set ---

# Password grant (for user accounts)
# KEYCLOAK_CLIENT_ID=your-wallet-client-id
# KEYCLOAK_USERNAME=your-username
# KEYCLOAK_PASSWORD=your-password
# PARTY_ID=your-party::1220...

# Client credentials grant (for service accounts)
# KEYCLOAK_CLIENT_ID=your-service-client-id
# KEYCLOAK_CLIENT_SECRET=your-client-secret
# PARTY_ID=your-party::1220...

# Optional: filter deposit accounts by owner (substring match)
# OWNER_FILTER=owner-party-name

# =============================================================================
# SHARED SETTINGS
# =============================================================================

# Destination Bitcoin address for withdrawals
# Devnet/Regtest: bcrt1q... | Testnet: tb1q... | Mainnet: bc1q...
DESTINATION_BTC_ADDRESS=

TRANSFER_AMOUNT=0.1
RECIPIENTS_CSV=recipients.csv
# AMOUNT_PER_RECEIVER=0.00001000
# KOL_JSON_PATH=kol_party_receivers.json

RUST_LOG=trace,tungstenite=error,tokio_tungstenite=error,reqwest=error

# =============================================================================
# CONTRACT DELETION
# =============================================================================
# CHOICE_CONTRACT_TEMPLATE_ID=#cbtc-governance:CBTC.Governance:CBTCGovernanceRules
# CHOICE_CONTRACT_ID=your-contract-id
# MAX_CONTRACTS=1000

# =============================================================================
# MARKER CREATION
# =============================================================================
# BENEFICIARIES_JSON=beneficiaries.json
# NUM_MARKERS=1
# BATCH_SIZE=200
# NUM_THREADS=1

# =============================================================================
# STREAM EXAMPLE
# =============================================================================
# RECEIVER_PARTY=receiver-party::1220...
# TRANSFER_COUNT=10

# =============================================================================
# TESTING
# =============================================================================
# LIB_TEST_MERCHANT_PASSWORD=
# LIB_TEST_RECEIVER_PARTY_ID=receiver-party::1220...
# LIB_TEST_TRANSFER_OFFER_CID=
# LIB_TEST_LEDGER_END_CLIENT_SECRET=your-client-secret-here
# LIB_TEST_AMULET_CLIENT_SECRET=your-amulet-client-secret-here
# WALLET_API_HOST=https://wallet.example.com
# CONSOLIDATION_THRESHOLD=2
